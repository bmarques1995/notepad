{
  "git": {
    "location": "https://code.qt.io/qt/qtwayland.git",
    "output_suffix": "qtwayland",
    "branch": "dev",
    "commit": "fc88dcfed73c0578d3bb562d9ff65c3aeff54c40",
    "patch": ""

  },
  "cmake": {
    "build_system": "ninja",
    "relative_root_location": "",
    "flags": [ 
        "-DQT_FEATURE_force_bundled_libs=ON", 
        "-DQT_FEATURE_wayland_server=ON", 
        "-DQT_FEATURE_wayland_client=ON" 
    ],
    "os_properties": {
      "windows": {
        "c_compiler": "clang-cl",
        "cxx_compiler": "clang-cl",
        "flags": [ "-DCMAKE_ASM_COMPILER=ml64" ]
      },
      "linux": {
        "c_compiler": "clang",
        "cxx_compiler": "clang++",
        "flags": [ "-DCMAKE_ASM_COMPILER=nasm" ]
      },
      "macos": {
        "c_compiler": "clang",
        "cxx_compiler": "clang++",
        "flags": [ "-DCMAKE_ASM_COMPILER=nasm" ]
      },
      "freebsd": {
        "c_compiler": "clang",
        "cxx_compiler": "clang++",
        "flags": [ "-DCMAKE_ASM_COMPILER=nasm" ]
      }
    }
  }
}
